    end

    DELTA["delta = delta_raw * sigmoid(gate_logits)"]
    FINALRES["final_residual = base_residual + delta"]
    FINALPRED["final_pred = prior + final_residual"]

    subgraph SIGNALS[Tail signals]
      direction LR
      GATE["gate target from abs error"] --> LOSS["Residual + gate + final losses"]
      WEIGHT["tail focus weights"] --> LOSS
    end

    INPUT --> BASE
