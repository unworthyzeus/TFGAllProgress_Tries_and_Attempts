flowchart TB
    subgraph DATA[Frozen stage1 outputs]
      direction LR
      INPUT["Stage1OutputDataset batch<br/>base inputs + stage1 prediction"] --> ABSERR["stage1_abs_error_db_f16"]
    end

    subgraph BASEPIPE[Frozen stage1 base]
      direction TB
      BASE["PMNetResidualRegressor<br/>base_channels = 112"] --> BASERES["base_residual"] --> BASEPRED["base_pred = prior + base_residual"]
    end

    PRIOR["Calibrated prior map"]
    REFIN["Refiner input concat<br/>x + base_pred + base_residual"]

